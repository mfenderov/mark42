{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "mark42 hook session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mark42 hook post-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mark42 hook stop",
            "async": true,
            "timeout": 30
          },
          {
            "type": "prompt",
            "prompt": "You are evaluating whether Claude should stop. Context: $ARGUMENTS\n\nIf stop_hook_active is true, respond {\"ok\": true}.\n\nOtherwise: check if this session had meaningful activity (multiple tool calls, code changes, architectural discussions, debugging). If yes, respond {\"ok\": false, \"reason\": \"Use the Task tool to spawn the mark42:knowledge-extractor agent in background mode. Reply only with the agent's summary.\"}. If the session was trivial (greetings, simple lookups, single question), respond {\"ok\": true}.",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "knowledge-extractor",
        "hooks": [
          {
            "type": "command",
            "command": "mark42 hook subagent-stop",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mark42 hook session-end",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "mark42 hook pre-compact",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
